{
  "mcpServers": {
    "vb-blender": {
      "type": "stdio",
      "command": "uv",
      "args": ["--directory", "Tools/mcp-toolkit", "run", "vb-blender-mcp"],
      "env": {
        "BLENDER_PORT": "9876",
        "BLENDER_HOST": "localhost",
        "ELEVENLABS_API_KEY": "${ELEVENLABS_API_KEY}",
        "GEMINI_API_KEY": "${GEMINI_API_KEY}",
        "TRIPO_API_KEY": "${TRIPO_API_KEY}",
        "FAL_KEY": "${FAL_KEY}"
      }
    },
    "vb-unity": {
      "type": "stdio",
      "command": "uv",
      "args": ["--directory", "Tools/mcp-toolkit", "run", "vb-unity-mcp"],
      "env": {
        "UNITY_PROJECT_PATH": "C:/Users/Conner/OneDrive/Documents/VeilBreakers3DCurrent",
        "ELEVENLABS_API_KEY": "${ELEVENLABS_API_KEY}",
        "GEMINI_API_KEY": "${GEMINI_API_KEY}"
      }
    },
    "vb-review": {
      "type": "stdio",
      "command": "uv",
      "args": ["--directory", "Tools/mcp-toolkit", "run", "vb-review-mcp"]
    }
  }
}
