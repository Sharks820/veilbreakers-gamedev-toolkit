+def _world_to_terrain_uv(
+    world_x: float,
+    world_y: float,
+    *,
+    terrain_size: float,
+    terrain_origin_x: float,
+    terrain_origin_y: float,
+) -> tuple[float, float]:
+    """Convert world coordinates to normalized terrain UVs.
+
+    ``terrain_origin_*`` is the terrain object's world-space center.
+    """
+    if terrain_size <= 0:
+        raise ValueError("terrain_size must be positive")
+
+    terrain_half = terrain_size * 0.5
+    local_x = world_x - terrain_origin_x + terrain_half
+    local_y = world_y - terrain_origin_y + terrain_half
+    return local_x / terrain_size, local_y / terrain_size
+
